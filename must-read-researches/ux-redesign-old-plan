### Database Migrations (Optional - New Features Only)

---

#### [NEW] meetings table (Supabase SQL)

```sql
CREATE TABLE IF NOT EXISTS public.meetings (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  requester_id UUID REFERENCES auth.users(id) NOT NULL,
  recipient_id UUID REFERENCES auth.users(id) NOT NULL,
  scheduled_at TIMESTAMP WITH TIME ZONE,
  status TEXT CHECK (status IN ('pending', 'confirmed', 'completed', 'cancelled')) DEFAULT 'pending',
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);
```

---

#### [NEW] meeting_reviews table (Supabase SQL)

```sql
CREATE TABLE IF NOT EXISTS public.meeting_reviews (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  meeting_id UUID REFERENCES public.meetings(id) ON DELETE CASCADE,
  reviewer_id UUID REFERENCES auth.users(id) NOT NULL,
  quality_positive BOOLEAN,
  value_positive BOOLEAN,
  would_meet_again BOOLEAN,
  private_note TEXT,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  UNIQUE(meeting_id, reviewer_id)
);
```

